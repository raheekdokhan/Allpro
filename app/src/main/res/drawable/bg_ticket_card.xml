<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- الظل الخلفي -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#DDDDDD"/> <!-- ظل خفيف -->
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- البطاقة الرئيسية -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:background="#FFFDE7"/> <!-- لون فاتح يوحي بالورق -->
            <corners android:radius="16dp"/>
            <stroke
                android:width="1dp"
                android:color="#2E7D32"/> <!-- حدود برتقالية لطيفة -->
        </shape>
    </item>



</layer-list>