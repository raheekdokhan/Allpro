<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- عنوان الصفحة -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- الحقول -->
        <EditText
            android:id="@+id/etFirstNameSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="First Name"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etLastNameSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="Last Name"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etUsernameSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="Email"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPhoneSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="Phone"
            android:inputType="phone"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAddressSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="Address"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPasswordSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="Password"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etConfirmPasswordSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="16sp"
            android:hint="Confirm Password"
            android:inputType="textPassword"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#757575"
            android:layout_marginBottom="20dp"/>

        <!-- الأزرار -->
        <Button
            android:id="@+id/btnSignupSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Signup"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnLoginSignup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Go to HomePage"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>